# Prisma / PostgreSQL (Supabase)
# Pooled connection for app runtime (pgbouncer)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection for Prisma migrations (non-pooled)
DIRECT_URL="postgresql://postgres:[password]@db.[project-ref].supabase.co:5432/postgres"

# Supabase Auth
NEXT_PUBLIC_SUPABASE_URL="https://xxx.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJ..."

# Supabase Admin (for seed script only — NEVER expose client-side)
# SUPABASE_URL="https://xxx.supabase.co"
# SUPABASE_SERVICE_ROLE_KEY="eyJ..."

# OpenRouter — https://openrouter.ai/keys
OPENROUTER_API_KEY="sk-or-v1-..."

# LLM models — any OpenRouter-compatible model ID
# NLP (voice/text parsing) — fast + cheap
LLM_NLP_MODEL="anthropic/claude-haiku-4-5"
# Vision (receipt photo parsing) — multimodal
LLM_VISION_MODEL="anthropic/claude-sonnet-4-6"

# Demo user constants (do not change — matches seed data)
NEXT_PUBLIC_DEMO_USER_ID="00000000-0000-0000-0000-000000000001"
NEXT_PUBLIC_DEMO_SQUAD_ID="00000000-0000-0000-0000-000000000010"
